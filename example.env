# nsrecord.net DNS server — example settings.
#
# Copy this file and edit it, then either:
#   - mount it into the container at /config/nsrecord.env, or
#   - pass it with `docker run --env-file nsrecord.env ...`, or
#   - reference it from docker-compose.yml via `env_file:`.
#
# Every value below is OPTIONAL. Leave a line commented (or blank) to use the
# server's built-in default. Values must not contain spaces.

# --- Your domain / nameservers -------------------------------------------------
# Delegate your domain to these nameservers at your registrar, then list their
# FQDNs (trailing dot) and their real public IPs (IPv4 and/or IPv6).
#NAMESERVERS=ns-0.nsrecord.net.,ns-1.nsrecord.net.
#ADDRESSES=ns-0.nsrecord.net=203.0.113.1,ns-1.nsrecord.net=203.0.113.2,ns-0.nsrecord.net=2001:db8::1,ns-1.nsrecord.net=2001:db8::2

# Domain used for PTR (reverse) records, e.g. "nsrecord.net." -> 1-2-3-4.nsrecord.net.
#PTR_DOMAIN=nsrecord.net.

# Comma-separated delegated domains for ACME DNS-01 wildcard challenges.
#DELEGATES=_acme-challenge.example.nsrecord.net=ns-1.awsdns-00.com.

# --- DNS server behavior -------------------------------------------------------
# Port the DNS server binds to inside the container (default 53).
#PORT=53

# Resolve public IPs? Set false to only resolve private/localhost ranges.
#PUBLIC=true

# Suppress per-query logging (set "true" to quiet logs).
#QUIET=false

# Where to fetch the phishing/scam blocklist (use file:// for an offline list).
#BLOCKLIST_URL=https://raw.githubusercontent.com/cunnie/sslip.io-blocklist/main/blocklist.txt

# --- Dashboard & stats ---------------------------------------------------------
# Bind address for the stats dashboard HTTP server (default ":8080"). Empty disables it.
DASHBOARD=:8080

# JSON file used to persist dashboard stats across restarts (mount /data as a volume).
STATS_FILE=/data/stats.json

# Path to the GeoLite2-Country .mmdb for per-country stats. The image already
# bakes one in at this path, so country stats work out of the box. Point this at
# a mounted file to use your own/newer DB, or set empty to disable country stats.
GEOIP=/geoip/GeoLite2-Country.mmdb
